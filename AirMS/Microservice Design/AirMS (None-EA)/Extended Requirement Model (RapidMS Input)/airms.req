		RepairsStatus : Integer // йПБеСіжЃ∞зїЂиѓ≤еЯЖ   йПИзГШоЭЂзТБжГІоШђйКЖдљЄеЯЧйНРе≥∞еЯЧйПЖж†ђоЖХжЊґеЫ•пњљдљЇеПОйПДеЇ°еЉЈжЄЪжґЪжХЄзТБжГІоШђйКЖдљЈзЈµеІШжЭСеЉЈйН¶зЖЈзЉУйР©з®њеПІйКЖдљєиЛѓжЭЮпЄЊжЈЃжЈЗоЗАоХ©зїЊпњљ
		DeviceId : String // зТБжГІоШђзЉВж†Іељњ
		Status :Integer // йОґгГ§жЕ®жЊґеЛ≠жВКйРШиИµпњљпњљ  ---еІЭгВЕзУІе®ИеЕЄе®ЗйРҐпњљ 0 йФЫпњљ1 йФЫпњљ2    йНТеЧЧеЯЖзРЫгДІгБЪisAccept=0 йФЫпњљ1   isComplete = 1  
		DescribeContent : String // йПБеСіжЃ∞йОїењЪе†™
		Score:Integer // зТЗеЛ™зОѓйНТеЧШжЪЯ  1~5йПДпњљ
		Remark:String // жЊґеЫ®жХЮ
