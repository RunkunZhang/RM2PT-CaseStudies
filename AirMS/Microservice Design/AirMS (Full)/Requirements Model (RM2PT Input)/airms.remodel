	Contract  AirportSystem::deleteUser(id : Integer) : Boolean {

		definition:
			user:User = User.allInstance()->any(u:User | u.Id = id)

		precondition:
			user.oclIsUndefined() = false

		postcondition:
			User.allInstance()->excludes(user) and
			result = true
	}

