		backtransmit(tbId, rejectCause) // й–«пҝҪйҚҘзӮІдјҗйҚ—пҝҪ
		setWorkTask(staffName, adminName, phone, section, remark) // йҺәжҺ”еҪ®
		setTerminalEquipment(name, address, description, type, remark, deviceInfoId) // йҚҠж¬җжәҖеҰӨиү°оҶ•жҫ¶пҝҪ

	}

