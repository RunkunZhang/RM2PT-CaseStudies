		setOperationStatus(name, value, valueUnit, status, remark, equipmentId) // з’Ғеү§з–ҶйҚҠж¬җжәҖеҰӨиү°оҶ•жҫ¶еӣӘз№ҚзҗӣеІҖе§ёйҚҗпҝҪ

	}

