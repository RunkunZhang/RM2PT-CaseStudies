DomainModel T {

	Entity WorkReport {
		Id:Integer
		Name:String
		Content:String
		Time:Date
	}

//  йҚҠиӮ©еҪ®зҗӣпҝҪ
	Entity WorkTask {
		Id:Integer
		StaffName:String // йҚҠиӮ©еҪ®жөңе“„оқҳйҚҡпҝҪ
		AdminName:String // йҺәжҺ”еҪ®жөңе“„оқҳйҚҡпҝҪ
		Phone:String // й‘ұж—ӮйғҙйҗўдҪғзҳҪ
		Section:String // йҚҠиӮ©еҪ®йҚ–жҙӘжЈҝ
		Remark:String
	}

//  йҚҠж¬җжәҖеҰӨиү°оҶ•жҫ¶еӣӘгҖғ
	Entity TerminalEquipment {
		Id:Integer
		Name:String // з’Ғжғ§оҳ¬йҚҡе¶ҮРһ
		Address:String // з’Ғжғ§оҳ¬йҚҰжқҝжҪғ
		Description:String // з’Ғжғ§оҳ¬йҺ»еҝҡе Ә
		Type:Integer // з’Ғжғ§оҳ¬з»«иҜІзҖ·
		Remark:String

		[Refer]
		BelongedDeviceInfo : DeviceInfo Association
	}

//  йҚҠж¬җжәҖеҰӨиү°оҶ•жҫ¶еӣӘз№ҚзҗӣеІҖе§ёйҚҗдҪғгҖғ
	Entity OperationStatus {
		Id:Integer
		Remark:String
		Status:String // йҗҳиҲөпҝҪпҝҪ
		Value:String // иӨ°ж’іеў йҚҠпҝҪ
		ValueUnit:String // йҚҠз…ҺеҙҹжөЈпҝҪ
		Time :Date // ж¶“е©ғе§ӨйҸғе •жЈҝ
		Name:String // ж¶“е©ғе§ӨжөңпҝҪ

		[Refer]
		BelongedEquipment : TerminalEquipment Association
	}

	Entity User {
		Id : Integer
		Name : String
		Password : String
		Phone : String

		[Refer]
		BelongedRole : Role Association
		BelongedDepartment : Department Association
	}

	Entity Role {
		Id : Integer // йҸ…оҮҖпҝҪж°ұж•ӨйҺҙеҮӨзҙқз»үжҲқо…»зјҒеҝ•жӮҠ й”ӣеІҖо…ёйҗһе—•жұүйҚӣпҝҪ й”ӣеІ„е„ҙй—Ӯг„©ж§Ұй—ҖпҝҪ й”ӣеІ„е„ҙй—Ӯг„ӨжұүйҚӣпҝҪ
		RoleCode :Integer
		Remark : String

		[Refer]
		ContainedUsers : User* ! Association
	}

	Entity Department { // й–®г„©жЈ¬ж·Үв„ғдј…зҗӣпҝҪ
	// й–®г„©жЈ¬зҒһеӮңйӘҮ   ----
	// ж¶“е©„йӘҮй–®г„©жЈ¬id ----
		Id:Integer
		Name:String
		ContactRerson:String // й–®г„©жЈ¬й‘ұж—ӮйғҙжөңпҝҪ
		Principal:String // й–®г„©жЈ¬з’җзҶ»зҹ—жөңпҝҪ
		Phone :String // й–®г„©жЈ¬й‘ұж—ӮйғҙйҗўдҪғзҳҪ
		BriefInfo :String // й–®г„©жЈ¬з» пҝҪжө пҝҪ
		DescribeContent:String // й–®г„©жЈ¬й‘ұеІғзҹ—йҺ»еҝҡе Ә
		Remark:String // жҫ¶еӣЁж•һ
	}

	Entity TbRepair { // йҺ¶гғӨж…Ёжө иҜІе§ҹзҗӣпҝҪ
		Id : Integer
		Repairname : String // йҺ¶гғӨж…ЁжөңпҝҪ
		Phone : String // йҺ¶гғӨж…ЁйҗўдҪғзҳҪ
		Place : String // йҺ¶гғӨж…ЁжөЈе¶Үз–Ҷ //жҗҙж—ҮоҮҡйҸҲеӨҠеҸҝжөЈж’¶ж®‘йҚ‘зҠұйҮңжөЈе¶Үз–Ҷжёҡж¶ўпҝҪеӨӢе«Ё
		RepairsStatus : Integer // йҸҒе‘ҙж®°з»«иҜІеҹҶ   йҸҲзғҳоқ«з’Ғжғ§оҳ¬йҠҶдҪёеҹ—йҚҗеі°еҹ—йҸҶж ¬оҶ•жҫ¶еӣҘпҝҪдҪәеҸҺйҸ„еәЎеј·жёҡж¶ҡж•ёз’Ғжғ§оҳ¬йҠҶдҪ·з·өе§ҳжқ‘еј·йҚҰзҶ·зј“йҗ©зЁҝеҸ§йҠҶдҪ№иӢҜжқһпёҫж·®ж·ҮоҮҖо•©з»ҫпҝҪ
		DeviceId : String // з’Ғжғ§оҳ¬зјӮж §еҪҝ
		Status :Integer // йҺ¶гғӨж…Ёжҫ¶еӢӯжӮҠйҗҳиҲөпҝҪпҝҪ  ---е§қгӮ…з“§еЁҲе…ёеЁҮйҗўпҝҪ 0 й”ӣпҝҪ1 й”ӣпҝҪ2    йҚ’е——еҹҶзҗӣг„§гҒҡisAccept=0 й”ӣпҝҪ1   isComplete = 1  
		DescribeContent : String // йҸҒе‘ҙж®°йҺ»еҝҡе Ә
		Score:Integer // з’ҮеӢӘзҺҜйҚ’е—ҳжҡҹ  1~5йҸ„пҝҪ
		Remark:String // жҫ¶еӣЁж•һ
		Time:Date // ж¶“е©ғе§ӨйҸғе •жЈҝ

		[Refer]
		BelongedUser : User Association // йҺ¶гғӨж…ЁжөңпҝҪ
		BelongedDepartment : Department Association
		AssoicatedTRE : TbRepairExtra Association
		BelongedEFT : EquipmentFailureType Association // йҸҒе‘ҙж®°з»«иҜІзҖ·
		[INV]
//		inv repairsStatus
	}

	Entity TbRepairExtra { // йҺ¶гғӨж…Ёжө иҜІе§ҹжҫ¶еӢӯжӮҠ  --------------ж¶“е©ғе§Өжөңе“„зҡўйҺ¶гғӨж…Ёжө иҜІе§ҹйҺёеӣ§з•ҫзјҒж¬Һз«ҙж¶“оҒҶж·®ж·ҮоҮҖе„ҙй—ӮпҝҪ
		Id : Integer
		Admin:Boolean // йҚҠж¬‘о…ёзҖ№в„ғзүі
		IsReject:Boolean // й–«пҝҪйҚҘпҝҪ
		RejectCause:String // й–«пҝҪйҚҘзӮІеё«йҚҘпҝҪ
		RelayNum:Integer // жқһо„ҖеҪӮеЁҶв„ғжҡҹ
		Arbitrate:Boolean // йҸ„оҲҡжғҒе®ёиҢ¬зІЎжө иҢ¶о—Ҷ
		IsAccept:Boolean // йҸ„оҲҡжғҒйҚҷжҘғжӮҠ
		IsComplete:Boolean // йҸ„оҲҡжғҒзҖ№еұҫеһҡзјҒзҝ ж…Ё
		Time:Date // зҖ№еұҫеһҡйҸғе •жЈҝ
		Resolvent:String // йҸҒе‘ҙж®°жҫ¶еӢӯжӮҠзҗӣеұјиҙҹ
		Cause:String // йҸҒе‘ҙж®°йҚҳзҶ·жҙң
		//

		[Refer]
		BelongedTbRepair : TbRepair Association
		BelongedAssignDepart : Department Association // йҺөпҝҪзҒһзӮәе„ҙй—Ӯг„§зҙӘйҚҷпҝҪ
		BelongedDistribution : User Association // йҺөпҝҪеЁІжғ§дјҗйҗўг„Ұеҹӣ
		BelongedRelayDep : Department Association // жқһо„ҖеҪӮй–®г„©жЈ¬    йҸҲиҷ№ж•ёй—ғзҶҙпҝҪдҪ№ж®©й–«ж°¶ж§ҰйҠҶдҪәж•ёйҚ”ж¶ўж§ҰйҠҶдҪәжӮЈйҚҡе Ҙж§ҰйҠҶдҪ№иӢҜжқһпёҝж…Ёйҗһе——е·¶
		[INV]
		
	}

	// йҺ¶гғӨж…Ёжө иҜІе§ҹжҫ¶еӢӯжӮҠзјҒзҝ ж…Ёз’җеңӯж•Ө
	Entity ProcessingFees {
		Id:Integer
		ProjectName:String // зјҒзҝ ж…ЁжӨӨеңӯжҙ°
		Price:Real // зјҒзҝ ж…ЁйҚ—жӣҡзҺҜ
		Number:Integer // зјҒзҝ ж…ЁйҸҒдјҙеҷә
		TotalPrice:Real // зјҒзҝ ж…ЁйҺ¬и®ізҺҜ
		Remake:String // жҫ¶еӣЁж•һ

		[Refer]
		BelongedTbRepair : TbRepair Association
	}

	Entity DeviceInfo { // з’Ғжғ§оҳ¬ж·Үв„ғдј…зҗӣпҝҪ
		Id:Integer //
		Name:String // з’Ғжғ§оҳ¬йҚҡе¶ҮРһ
		Brand:String // з’Ғжғ§оҳ¬йҚқдҪәеўқ
		Type:String // з’Ғжғ§оҳ¬йҚЁе¬ӘеҪҝ
		Address:String // з’Ғжғ§оҳ¬зҖ№еӨҺо—ҠжөЈе¶Үз–Ҷ
		AdminName:String // з’Ғжғ§оҳ¬з» пј„жӮҠжөңпҝҪ
		ContactsName:String // з’Ғжғ§оҳ¬й‘ұж—ӮйғҙжөңзғҳжҹҹеҜ®пҝҪ
		Status:Integer // з’Ғжғ§оҳ¬иӨ°ж’іеў йҗҳиҲөпҝҪпҝҪ
		Remark:String // жҫ¶еӣЁж•һ

		[Refer]
		BelongedDLG:DeviceLocationGroup Association // з’Ғжғ§оҳ¬жөЈе¶Үз–ҶйҚ’е—ҷзІҚ
		BelongedEFT:EquipmentFailureType Association // з’Ғжғ§оҳ¬йҸҒе‘ҙж®°з»«иҜІзҖ·
		BelongedDAG:DeviceAssociationGroup Association // з’Ғжғ§оҳ¬йҚҸе® д»ҲйҚ’е—ҷзІҚ
		BelongedDepartment:Department Association // з’Ғжғ§оҳ¬йҺөпҝҪзҒһзӮәе„ҙй—ӮпҝҪ
//		// йҸҒе‘ҙж®°йҺөпҝҪзҒһзӮәе„ҙй—ӮпҝҪ ----
	}

	Entity DeviceLocationGroup { // з’Ғжғ§оҳ¬жөЈе¶Үз–ҶйҚ’е—ҷзІҚ
		Id:Integer //
		Name:String // з’Ғжғ§оҳ¬жөЈе¶Үз–ҶйҚҡе¶ҮРһ
		Remark:String // жҫ¶еӣЁж•һ
	}

	Entity EquipmentFailureType { // з’Ғжғ§оҳ¬йҸҒе‘ҙж®°з»«иҜІзҖ·
		Id:Integer
		Name:String //
		DescribeContent:String // з’Ғжғ§оҳ¬йҸҒе‘ҙж®°й‘·оҒ…о—…йҺ»еҝҡе Ә
		Remark:String // жҫ¶еӣЁж•һ

		[Refer]
		BelongedDepartment:Department Association // з’Ғжғ§оҳ¬йҸҒе‘ҙж®°з»«иҜІзҖ·йҺөпҝҪзҒһзӮәе„ҙй—ӮпҝҪ
	}

	Entity DeviceStatus { // з’Ғжғ§оҳ¬йҗҳиҲөпҝҪпҝҪ
		Id:Integer //
		Name:String //
		Remark:String // жҫ¶еӣЁж•һ
	}

	Entity DeviceAssociationGroup { // з’Ғжғ§оҳ¬йҚҸе® д»ҲйҚ’е—ҷзІҚ
		Id:Integer //
		Name:String //
		Remark:String
	}

}

